{
  "openapi": "3.0.0",
  "info": {
    "title": "CSE 341 Contacts API",
    "version": "1.0.0",
    "description": "API documentation for Contacts Project Part 2"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local server"
    }
  ],
  "tags": [
    {
      "name": "Contacts",
      "description": "Contacts CRUD endpoints"
    }
  ],
  "paths": {
    "/contacts": {
      "get": {
        "tags": ["Contacts"],
        "summary": "Get all contacts",
        "responses": {
          "200": {
            "description": "Contacts returned",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ContactWithId"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Contacts"],
        "summary": "Create a contact",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ContactInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Contact created"
          },
          "400": {
            "description": "Invalid input"
          }
        }
      }
    },
    "/contacts/{id}": {
      "get": {
        "tags": ["Contacts"],
        "summary": "Get one contact by id",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Contact returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContactWithId"
                }
              }
            }
          },
          "400": {
            "description": "Invalid id"
          },
          "404": {
            "description": "Not found"
          }
        }
      },
      "put": {
        "tags": ["Contacts"],
        "summary": "Update an existing contact",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ContactInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contact updated"
          },
          "400": {
            "description": "Invalid id or payload"
          },
          "404": {
            "description": "Not found"
          }
        }
      },
      "delete": {
        "tags": ["Contacts"],
        "summary": "Delete a contact",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Contact deleted"
          },
          "400": {
            "description": "Invalid id"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ContactInput": {
        "type": "object",
        "required": ["firstName", "lastName", "email", "favoriteColor", "birthday"],
        "properties": {
          "firstName": {
            "type": "string",
            "example": "Parker"
          },
          "lastName": {
            "type": "string",
            "example": "Jones"
          },
          "email": {
            "type": "string",
            "example": "parker.jones@example.com"
          },
          "favoriteColor": {
            "type": "string",
            "example": "Blue"
          },
          "birthday": {
            "type": "string",
            "example": "1999-04-12"
          }
        }
      },
      "ContactWithId": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ContactInput"
          },
          {
            "type": "object",
            "properties": {
              "_id": {
                "type": "string",
                "example": "686f13a01d8b3e2a12345678"
              }
            }
          }
        ]
      }
    }
  }
}
